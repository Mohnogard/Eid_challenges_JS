<!DOCTYPE html>
<head>
    <title>Challenge_1</title>
</head>
<body>
    <script>

let data = [
  { event:"click", time:1 },
  { event:"click", time:4 },
  { event:"scroll", time:2 },  
  { event:"scroll", time:3 },
  { event:"click", time:5 }
]
let result = []
let counter =1

for (let i=0; i<data.length; i++){
    for (let j=0; j<data.length-1; j++){
        let storage
        if (data[j].time>data[j+1].time){
            storage = data[j]
            data[j]=data[j+1]
            data[j+1]=storage
        }
    }
}

for (let i = 0; i < data.length - 1; i++) {
    if (data[i].event === data[i + 1].event) {
        counter++;
    } else {
        result.push({
            event: data[i].event,
            count: counter
        });
        counter = 1;
    }
}

result.push({
    event: data[data.length - 1].event,
    count: counter
});

console.log(result)
    </script>
</body>
