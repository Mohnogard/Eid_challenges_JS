<!DOCTYPE html>
<head>
    <title>Challenge_3</title>
</head>
<body>
    <script>

let arr=[12,2,9,3,10,1,10,0,3,1,1,10,14]
let max =0
let smallest = arr[0]
let smallestindex = 0
let buyIndex = 0
let sellIndex = 0
console.log(arr)

for (let i = 1; i < arr.length; i++) {
    if (arr[i] < smallest) {
        smallest = arr[i]   // update best buy so far
        smallestindex=i
    } else {
        let profit = arr[i] - smallest
        if (profit > max) {
            max = profit
            sellIndex=i
            buyIndex=smallestindex
        }
    }
}
console.log("The max profit would be if you buy at: ", buyIndex, " for the price of: ",smallest,"$$")
console.log("And sell at: ", sellIndex, " for the price of ", max,'$$')
console.log('Proft: ', max, '$$$!')

    </script>
</body>
