    <script>
let data=[3,2,4,1,2,3,4,5,2,1,6,7,8,2,3]
let target = [1,2,3,4,5]

function smallestpart(arr, target){
    let indexes=[]
    let index = []
    let large= target[target.length-1]
    let small=target[0]
    let counter=1
    loop: for (let i=0;i<arr.length;i++){
                if (arr[i]===small){
                    indexes.push(arr[i])
                    index.push(i)
                for (let x=i+1; x<arr.length;x++){

                    if ((arr[x])===target[counter]){
                        indexes.push(arr[x+1])
                        counter+=1
                    } else {
                        indexes=[]
                        index=[]
                        break
                    } 
                    if(indexes.length===(target.length)){
                        index.push(x+1)
                        break loop
                    }
            }
        }
    }
    if (index.length==0){
        return("Not found")
    }
    console.log("The shortest part: "+target+ " is at these positions: ", index)
}

