<body>
    <script>

free = [2,-2,2,2,-1] 
stuck = [3,-1,-1,1,-2]

function detectcycle(arr){
let update=0
let visited=[]
loop: for (let i=0;0<=i && i<arr.length;){
    update+=arr[i] //the value of where I will be
    i=update
    for (let j=0;j<visited.length && visited.length>1;j++){
        if (visited[j]==update){
            console.log("INFINITE CYCLE DETECTED")
            break loop
        }
    }
    visited.push(i)
    if(i>arr.length-1 || i<0){
        console.log("no issue")
    }
}

}

detectcycle(free)
detectcycle(stuck)

    </script>
</body>
