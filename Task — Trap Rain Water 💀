<!DOCTYPE html>
<head>
    <title></title>
</head>
<body>
    <script>
let height = [0,1,0,2,1,0,1,3,2,1,2,1];
let totalwater = 0;


for (let i=0; i<height.length;i++){
    let leftMax=0
    let rightMax=0

    for (j=0;j<=i;j++){
        if (height[j]>leftMax){
            leftMax=height[j]
        } 
    }

    for (j=i;j<height.length;j++){
        if (height[j]>rightMax){
            rightMax=height[j]
        } 
    }
    let water = Math.min(leftMax, rightMax)-height[i]  
    totalwater+=water

}
console.log(totalwater); // 6
    </script>
</body>
